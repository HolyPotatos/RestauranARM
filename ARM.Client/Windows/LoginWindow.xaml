<Window x:Class="ARM.Client.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ARM.Client.Windows"
        mc:Ignorable="d"
        Title="Авторизация" Height="480" Width="380" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="{DynamicResource BgColor}">
    <Grid>
        <Border Background="{DynamicResource SecondaryBgColor}"
                BorderBrush="{DynamicResource BorderDefaultColor}"
                BorderThickness="1"
                CornerRadius="12"
                Margin="30"
                Padding="30">

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="АРМ Ресторана" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource TextPrimaryColor}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>

                <TextBlock Text="Вход в систему" 
                           FontSize="14" 
                           Foreground="{DynamicResource TextSecondaryColor}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Логин" 
                           Foreground="{DynamicResource TextSecondaryColor}" 
                           Margin="0,0,0,5"/>
                <TextBox x:Name="LoginTextBox" 
                         Style="{StaticResource TextBoxStyle}" 
                         Tag="Введите логин" 
                         Height="42" 
                         Margin="0,0,0,15"/>

                <TextBlock Text="Пароль" 
                           Foreground="{DynamicResource TextSecondaryColor}" 
                           Margin="0,0,0,5"/>
                <Grid Height="42" Margin="0,0,0,25">
                    <PasswordBox x:Name="UserPasswordBox" 
                                 Style="{StaticResource PasswordBoxStyle}"
                                 PasswordChanged="UserPasswordBox_PasswordChanged"
                                 GotFocus="UserPasswordBox_GotFocus"
                                 LostFocus="UserPasswordBox_LostFocus"/>

                    <TextBlock x:Name="PasswordPlaceholder"
                               Text="Введите пароль"
                               Foreground="{DynamicResource TextSecondaryColor}"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Margin="13,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                <Button x:Name="LoginButton" Grid.Column="1"
                        Content="Войти"
                        Margin="5,0,0,0"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Height="45"
                        Click="LoginButton_Click"/>

                    <Button x:Name="CancelButton" Grid.Column="0"
                        Content="Отмена"
                        Margin="0,0,5,0"
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Height="45"
                        Click="CancelButton_Click"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>
